{
  "name": "nervous-system",
  "version": "0.1.0",
  "private": true,
  "description": "NERVous System — a modular multi-agent coding-agent extension framework for pi. This repo hosts one pi package per component.",
  "workspaces": [
    "magi",
    "axon",
    "synapse",
    "cortex",
    "lion",
    "cerebel",
    "ganglion",
    "amygdala",
    "dashboard"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:magi": "vitest run --dir magi",
    "test:axon": "vitest run --dir axon",
    "test:synapse": "vitest run --dir synapse",
    "test:cortex": "vitest run --dir cortex",
    "test:lion": "vitest run --dir lion",
    "test:cerebel": "vitest run --dir cerebel",
    "test:ganglion": "vitest run --dir ganglion",
    "test:amygdala": "vitest run --dir amygdala",
    "test:dashboard": "vitest run --dir dashboard",
    "test:e2e": "vitest run demo/tests/e2e-flow.test.ts"
  },
  "devDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "@types/node": "^22.0.0",
    "typebox": "*",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
